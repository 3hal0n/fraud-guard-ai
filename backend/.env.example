# Copy to backend/.env and fill in your values. Do NOT commit real secrets.
#
# Find your connection string in:
#   Supabase → Project Settings → Database → Connection string → URI
# Use the Transaction Pooler URL (port 6543) for best compatibility.
#
# IMPORTANT: append ?options=-c%20search_path%3Dfraudguard to target the
# correct schema (the one shown in your Supabase Database Tables view).
#
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?options=-c%20search_path%3Dfraudguard

# Alternative key name (either works; DATABASE_URL takes priority):
# SUPABASE_DB_URL=postgresql://...

# CORS – comma-separated allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Clerk webhook secret (if you add webhook signature verification)
# CLERK_WEBHOOK_SECRET=YOUR_CLERK_WEBHOOK_SECRET
